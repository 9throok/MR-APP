# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Database ──────────────────────────────────────────────────────────────────
# Local Docker Postgres (docker-compose.local.yml overrides this automatically)
# No need to set this for local dev — it's set in docker-compose.local.yml
# DATABASE_URL=postgresql://postgres:password@localhost:5433/zenapp

# For production Supabase, use your Supabase connection string:
# DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres

# ── Supabase (production only — not used locally) ─────────────────────────────
# SUPABASE_URL=https://<project-ref>.supabase.co
# SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Pick one: openai | groq | anthropic | gemini
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.0-flash
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.3

# ── LLM API Keys (only the one matching LLM_PROVIDER is required) ─────────────
OPENAI_API_KEY=your_openai_api_key_here
GROQ_API_KEY=your_groq_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here  # Also used for RAG embeddings (text-embedding-004)

# Required only for Groq
LLM_BASE_URL=https://api.groq.com/openai/v1
